  m_Script: {fileID: 11500000, guid: c4454ddfc1b9bcf4080a4b41117d5454, type: 3}
  m_Name: "B4.B\xFCrgerkrieg"
  m_EditorClassIdentifier: 
  speakerName: Chap
  NewsImage: {fileID: 2055342799203861237, guid: c49bb095256fca647998e7cb7cc26fc5, type: 3}
  lines:
  - "Eilmeldung, es ist zu K\xE4mpfen zwischen Regierungstruppen und Teilen der Rebellen
    gekommen. Damit befinden wir uns nun offiziell in einem B\xFCrgerkrieg. Die K\xE4mpfe
    waren bisher ziemlich ausgeglichen."
  - "Es gab Verluste auf beiden Seiten. Beide k\xFCndigten deshalb auch Vergeltungsschl\xE4ge
    an. Die Rebellen haben angek\xFCndigt nicht aufzuh\xF6ren, bis Pr\xE4sident Rodrigues
    abgesetzt ist. Ein schnelles Ende des Krieges ist also nicht in Sicht."
